# Chutkima Admin Dashboard — environment template
# Copy to `.env` for local dev, or set these in Vercel → Project → Settings → Environment Variables.
# All client-exposed vars MUST be prefixed with VITE_.
# Every var is OPTIONAL — sensible defaults are used if unset (the app runs on mock data).

# Backend API base URL (only used once real APIs replace the mock layer).
VITE_API_BASE_URL=https://api.chutkima.example/v1

# App display name.
VITE_APP_NAME=Chutkima Admin

# Use in-memory mock data ("true") instead of calling a real backend ("false").
VITE_USE_MOCKS=true
